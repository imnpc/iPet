{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "laravel/laravel",
    "type": "project",
    "description": "The skeleton application for the Laravel framework.",
    "keywords": ["laravel", "framework"],
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "amidesfahani/filament-tinyeditor": "^4.0",
        "bavix/laravel-wallet": "^12.0",
        "bezhansalleh/filament-language-switch": "^4.1",
        "bezhansalleh/filament-shield": "^4.0",
        "codewithdennis/filament-lucide-icons": "^4.0",
        "dedoc/scramble": "^0.13.12",
        "devonab/filament-easy-footer": "^2.0",
        "filament/filament": "^5.0",
        "filament/spatie-laravel-tags-plugin": "^5.0",
        "geoip2/geoip2": "^3.2",
        "imnpc/captcha": "^13.0",
        "imnpc/filament-bandel": "^6.0",
        "imnpc/filament-wallet": "^5.0",
        "imnpc/laravel-flysystem-oss": "^3.0",
        "interaction-design-foundation/laravel-geoip": "^4.2",
        "laravel/framework": "^13.0",
        "laravel/horizon": "^5.33",
        "laravel/sanctum": "^4.0",
        "laravel/tinker": "^3.0",
        "leonis/easysms-notification-channel": "^3.0",
        "livewire/livewire": "^4.0",
        "maatwebsite/excel": "^3.1",
        "maggomann/filament-model-translator": "^1.1",
        "marcelweidum/filament-passkeys": "^3.0",
        "outerweb/filament-settings": "^2.0",
        "outerweb/settings": "^2.0",
        "overtrue/laravel-wechat": "^8.0",
        "owenvoke/blade-fontawesome": "^3",
        "plank/laravel-mediable": "^6.3",
        "pxlrbt/filament-environment-indicator": "^3.0",
        "pxlrbt/filament-excel": "^3.0",
        "resend/resend-laravel": "^1.3",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "spatie/laravel-activitylog": "^5.0",
        "spatie/laravel-query-builder": "^7.0",
        "spatie/laravel-route-attributes": "^1.25",
        "stechstudio/filament-impersonate": "^5.4",
        "stijnvanouplines/blade-country-flags": "^1.0",
        "vinkla/hashids": "^14.0",
        "yansongda/laravel-pay": "~3.7.0",
        "ysfkaya/filament-phone-input": "^4.0"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^3.6",
        "fakerphp/faker": "^1.23",
        "laravel-lang/lang": "^15.22",
        "laravel/boost": "^2.4",
        "laravel/pail": "^1.2.2",
        "laravel/pint": "^1.13",
        "laravel/sail": "^1.41",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "overtrue/laravel-query-logger": "^5.0",
        "phpunit/phpunit": "^12.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "bootstrap/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan filament:upgrade"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi",
            "@php -r \"file_exists('database/database.sqlite') || touch('database/database.sqlite');\"",
            "@php artisan migrate --graceful --ansi"
        ],
        "dev": [
            "Composer\\Config::disableProcessTimeout",
            "npx concurrently -c \"#93c5fd,#c4b5fd,#fb7185,#fdba74\" \"php artisan serve\" \"php artisan queue:listen --tries=1\" \"php artisan pail --timeout=0\" \"npm run dev\" --names=server,queue,logs,vite"
        ],
        "test:sqlite": [
            "APP_ENV=testing DB_CONNECTION=sqlite DB_DATABASE=':memory:' SESSION_DRIVER=array CACHE_STORE=array QUEUE_CONNECTION=sync MAIL_MAILER=array php artisan config:clear --ansi",
            "APP_ENV=testing DB_CONNECTION=sqlite DB_DATABASE=':memory:' SESSION_DRIVER=array CACHE_STORE=array QUEUE_CONNECTION=sync MAIL_MAILER=array WALLET_LOCK_DRIVER=array WALLET_CACHE_DRIVER=array php artisan test --compact"
        ],
        "test": [
            "@test:sqlite"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "block-insecure": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
